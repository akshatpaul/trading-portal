# Environment — NEVER commit
.env
*.env.local
.deploy.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environment
venv/
.venv/
env/
ENV/

# pyright / mypy / ruff
.mypy_cache/
.ruff_cache/
.pytype/
pyrightconfig.json

# SQLite databases (use migrations, not raw db files)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Node / Frontend
node_modules/
frontend/dist/
frontend/.cache/
frontend/build/

# Vite
.vite/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
