# ─────────────────────────────────────────────
# Trading Portal — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Zerodha Kite Connect ──────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application ───────────────────────────────
APP_MODE=paper
APP_HOST=localhost
APP_PORT=8000
SECRET_KEY=your-secret-key-change-this

# ── Capital ───────────────────────────────────
STARTING_CAPITAL=10000

# ── Data Source ───────────────────────────────
DATA_SOURCE=yfinance
DATA_DELAY_MINUTES=15

# ── Safety Limits (also hardcoded in risk_manager.py) ──
MAX_DAILY_LOSS=300
MAX_TRADES_PER_DAY=3
MAX_POSITION_SIZE=5000
MAX_LEVERAGE=2
FORCE_CLOSE_TIME=15:10

# ── Future AWS Deployment (leave blank for now) ──
AWS_INSTANCE_ID=
DOMAIN=

# ── Auth ──────────────────────────────────────────────────────
TRADING_USERNAME=admin
TRADING_PASSWORD_HASH=   # generate with: python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRE_HOURS=24
